# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nginx_warden_db?schema=public"

DB_NAME=nginx_warden_db
DB_USER=postgres
DB_PASSWORD=postgres
# Server Configuration
PORT=3001
# HTTP bind address (0.0.0.0 = listen on all interfaces; use for LAN/private IP API access)
HOST=0.0.0.0
NODE_ENV=production

# JWT Configuration
JWT_ACCESS_SECRET="change-this-to-random-secret"
JWT_REFRESH_SECRET="change-this-to-random-secret"
JWT_ACCESS_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration (comma-separated origins)
CORS_ORIGIN="http://localhost:8088,http://localhost:5173,http://YOUR_PUBLIC_IP:8088"

# Security
BCRYPT_ROUNDS=10

# Session
SESSION_SECRET="change-this-to-random-secret"

# 2FA
TWO_FACTOR_APP_NAME=Nginx Warden

# SSL Configuration
SSL_DIR="/etc/nginx/ssl"
ACME_DIR="/var/www/html/.well-known/acme-challenge"

# SMTP Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="change-this-to-random-password"

# Frontend Configuration (used at build time; use "auto" so the SPA calls same host:3001/api as the browser)
# VITE_API_URL=http://localhost:3001/api
VITE_API_URL=auto

# API: path to Nginx Warden monorepo root if not two levels above apps/api cwd
# NGINX_WARDEN_ROOT=/opt/nginx-warden
# ENABLE_WEB_SYSTEM_UPDATE=true
