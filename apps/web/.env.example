# Application Configuration
VITE_APP_NAME=Nginx ModSecurity Portal
VITE_APP_VERSION=1.0.0

# Secret Login Path (default: /login)
# Change this to a custom path for added security
VITE_SECRET_LOGIN_PATH=/portal-secret/login

# API Configuration
# By default the SPA calls the API on the SAME hostname as the page (port VITE_API_PORT / 3001).
# Old builds used to set VITE_API_URL to a public IP — that is ignored at runtime unless you opt in:
# VITE_API_USE_FIXED=true
# VITE_API_URL=https://api.example.com/api
#
# VITE_API_PORT=3001
VITE_API_URL=auto

# Feature Flags
VITE_ENABLE_SSO=true
VITE_ENABLE_2FA=true
VITE_ENABLE_AUTO_SSL=true

# Monitoring
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_ID=

# Session
VITE_SESSION_TIMEOUT=3600

# Demo Mode (for development only)
VITE_DEMO_MODE=true
