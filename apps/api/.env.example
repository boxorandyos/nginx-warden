# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nginx_warden_db?schema=public"

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# Monorepo root on disk (parent of apps/api). Required if API cwd is not apps/api.
# NGINX_WARDEN_ROOT=/var/www/nginx-warden

# VRRP / Keepalived (High Availability) — after enabling in the UI (master) and syncing, slaves can override the NIC name:
# WARDEN_KEEPALIVED_INTERFACE=eth0
# KEEPALIVED_CONF_PATH=/etc/keepalived/keepalived.conf

# Fleet → Configuration → "Update from GitHub" (git pull + scripts/update.sh). Set false to disable.
# ENABLE_WEB_SYSTEM_UPDATE=true

# Git ref for UI-triggered update (remote must exist, e.g. origin from GitHub)
# UPDATE_GIT_REMOTE=origin
# UPDATE_GIT_BRANCH=main
# Set true to skip "git stash -u" before pull (not recommended)
# UPDATE_GIT_NO_STASH=false

# Optional: override path read by GET /system-config/system-update-log (default /var/log/nginx-warden-ui-update.log)
# NGINX_WARDEN_UI_UPDATE_LOG=/var/log/nginx-warden-ui-update.log

# Host firewall (Fleet → Firewall): set true on dev/non-Linux to skip nft -f (still writes audit log)
# NFT_APPLY_DISABLED=false
# NGINX_WARDEN_VAR_DIR=/var/lib/nginx-warden
# NFT_BINARY=/usr/sbin/nft

# CrowdSec: production deploy runs scripts/crowdsec-autoconfigure.sh — sets CROWDSEC_LAPI_URL + CROWDSEC_API_KEY and applies the firewall bouncer template (LAPI default 127.0.0.1:9091, override CROWDSEC_LAPI_PORT).
# CROWDSEC_LAPI_URL=http://127.0.0.1:9091
# CROWDSEC_API_KEY=
# Manual firewall template only if not using deploy autoconfigure: scripts/apply-crowdsec-firewall-bouncer-template.sh (CROWDSEC_BOUNCER_API_KEY)

# Per-vhost CrowdSec (optional): emit CrowdSec nginx Lua in generated vhosts when true on the API host.
# ENABLE_CROWDSEC_NGINX_LUA=false
# Optional include for AppSec connector rules (must exist on disk before nginx -t passes).
# CROWDSEC_APPSEC_INCLUDE=/etc/nginx/modsec/crowdsec-appsec.inc

# After domain create/update/regenerate, probe upstream GET healthCheckPath (non-blocking). Default off.
# UPSTREAM_HEALTH_ON_SAVE=false

# JWT Configuration
JWT_ACCESS_SECRET="change-this-to-random-secret"
JWT_REFRESH_SECRET="change-this-to-random-secret"
JWT_ACCESS_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration (comma-separated origins). Use your browser URL origin, e.g. http://10.0.0.5:8088 for LAN.
CORS_ORIGIN="http://localhost:8088,http://127.0.0.1:8088,http://localhost:5173"

# Security
BCRYPT_ROUNDS=10
# Session
SESSION_SECRET="change-this-to-random-secret"

# 2FA
TWO_FACTOR_APP_NAME=Nginx Warden

# SSL Configuration
SSL_DIR="/etc/nginx/ssl"
ACME_DIR="/var/www/html/.well-known/acme-challenge"

# SMTP Configuration
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="change-this-to-random-password"